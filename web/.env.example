# Production: your Render service URL (no trailing slash). Dev: leave empty — Vite proxies /api and /uploads.
VITE_PUBLIC_API_ORIGIN=https://your-service.onrender.com

# Required for public reader sign-in: Web OAuth client ID (same project as backend GOOGLE_CLIENT_ID).
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

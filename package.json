{
  "name": "news-kothari",
  "private": true,
  "description": "Monorepo root — run scripts in web-next, cms, or backend",
  "scripts": {
    "dev:web-next": "npm --prefix web-next run dev",
    "build:web-next": "npm --prefix web-next run build",
    "start:web-next": "npm --prefix web-next run start",
    "lint:web-next": "npm --prefix web-next run lint",
    "dev:cms": "npm --prefix cms run dev",
    "build:cms": "npm --prefix cms run build",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start"
  }
}

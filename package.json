{
  "name": "news-kothari",
  "private": true,
  "description": "Monorepo root — run scripts in web, cms, or backend",
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "lint:web": "npm --prefix web run lint",
    "preview:web": "npm --prefix web run preview",
    "dev:cms": "npm --prefix cms run dev",
    "build:cms": "npm --prefix cms run build",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start"
  }
}

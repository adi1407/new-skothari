PORT=5000
NODE_ENV=production

# MongoDB Atlas or other hosted Mongo
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/kothari-news

JWT_SECRET=use_a_long_random_string
JWT_EXPIRES_IN=7d

# Optional: public site readers (same secret as JWT_SECRET if unset)
# READER_JWT_SECRET=
# READER_JWT_EXPIRES_IN=30d

# Google Sign-In for readers (Web client ID; optional)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Public site (Vercel). Comma-separated for multiple origins (e.g. preview + production).
CLIENT_URL=https://your-app.vercel.app
# CLIENT_URLS=https://your-app.vercel.app,https://www.yourdomain.com

# First admin (seeded once on first DB connection)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Super Admin

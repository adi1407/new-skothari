PORT=5050
# Local dev: use development so CORS allows LAN testing. Production deploy: production + CLIENT_URL.
NODE_ENV=development

# ── MongoDB Atlas (recommended) ─────────────────────────────────────────────
# Atlas → Database → Connect → Drivers → copy the mongodb+srv:// string.
# Replace <password> with your DB user password. Encode special characters in the password:
#   @ → %40   # → %23   / → %2F   : → %3A   etc.
# Atlas → Network Access → Add IP Address (your current IP, or 0.0.0.0/0 for dev only).
# Atlas → Database Access → create a database user (read/write on your cluster).
#
# Example:
# MONGO_URI=mongodb+srv://myuser:MyEncodedPass@cluster0.ab12cd.mongodb.net/kothari-news?retryWrites=true&w=majority
#
# Optional: self-hosted Mongo instead of Atlas:
# MONGO_URI=mongodb://127.0.0.1:27017/kothari-news
MONGO_URI=mongodb+srv://user:pass@cluster0.YOUR_CLUSTER_REF.mongodb.net/kothari-news?retryWrites=true&w=majority

JWT_SECRET=use_a_long_random_string
JWT_EXPIRES_IN=7d

# Optional: public site readers (same secret as JWT_SECRET if unset)
# READER_JWT_SECRET=
# READER_JWT_EXPIRES_IN=30d

# Google Sign-In for readers (Web OAuth client ID — required for public /api/reader/auth/google)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Newsletter sync when readers toggle newsletter in profile (optional; pick one approach):
# NEWSLETTER_WEBHOOK_URL=https://your-automation/webhook  → POST JSON { email, displayName, action: subscribe|unsubscribe }
# Or Resend Audiences: RESEND_API_KEY + RESEND_NEWSLETTER_AUDIENCE_ID
#
# Automated digest emails (latest published articles via Resend transactional API):
# RESEND_API_KEY=re_xxxxx   # same key can power audiences + transactional sends
# NEWSLETTER_FROM="Kothari News <newsletter@yourverifieddomain.com>"
# NEWSLETTER_SITE_URL=https://your-public-site.com   # links in email; defaults to first CLIENT_URL if unset
# NEWSLETTER_BRAND=Kothari News   # optional subject/header branding
# Public POST /api/public/newsletter/subscribe accepts optional { digestCadence: "daily"|"weekly" }.
# Logged-in readers use profile digestCadence + preferredCategories / newsletterTopics for personalized digests.
# Cron example: npm run newsletter:digest --prefix backend
#
# CMS forgot-password: the OTP is always returned in the POST /api/auth/forgot-password JSON for the CMS UI when a code is issued (use HTTPS in production).
# Optional: set both to also email the code via Resend (verified sender/domain):
# RESEND_API_KEY=re_xxxxx
# CMS_PASSWORD_RESET_FROM="Kothari CMS <noreply@yourverifieddomain.com>"

# Public site + CMS origins — required when NODE_ENV=production for browser CORS.
# Exact origins (scheme + host + port, no path). Use CLIENT_URLS when web-next and CMS are on different Vercel URLs.
# CLIENT_URL=https://your-news.vercel.app
# CLIENT_URLS=https://your-news.vercel.app,https://your-news-cms.vercel.app
CLIENT_URL=https://your-app.vercel.app

# First admin (seeded once on first DB connection)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Super Admin

# Optional: English / Hindi desk writers (created once if missing; same password by default)
# SEED_WRITER_PASSWORD=Writer@1234
# SEED_WRITER_EN_EMAIL=writer.en@kotharinews.com
# SEED_WRITER_EN_NAME=English Desk Writer
# SEED_WRITER_HI_EMAIL=writer.hi@kotharinews.com
# SEED_WRITER_HI_NAME=Hindi Desk Writer

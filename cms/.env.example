# Copy to `.env` or `.env.local` for local CMS (optional — Vite proxies `/api` when unset).
#
# Vercel / production: set to your Railway (or other) API origin — no trailing slash.
# Vercel → Project → Settings → Environment Variables → `VITE_API_ORIGIN`
#
# Example:
# VITE_API_ORIGIN=https://kothari-news-api.up.railway.app

VITE_API_ORIGIN=
